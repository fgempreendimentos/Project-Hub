# --- Aplicação ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Banco de dados ---
DATABASE_URL="file:./src/database/dev.db"

# --- WhatsApp ---
WHATSAPP_GROUP_ID=
# Pasta onde a sessão do Baileys (QR/credenciais) é persistida. Nunca commitar.
WHATSAPP_AUTH_DIR=./auth
# Intervalo mínimo entre envios (ms), para evitar flood/banimento
WHATSAPP_MIN_INTERVAL_MS=20000

# --- IA (geração de texto da oferta) ---
OPENAI_KEY=

# --- Links de afiliado ---
AFFILIATE_AMAZON=
AFFILIATE_SHOPEE=
AFFILIATE_MERCADOLIVRE=

# --- Filtros de validação de oferta ---
MIN_DISCOUNT_PERCENT=20
MIN_RATING=4
MIN_REVIEWS_COUNT=50

# --- Scheduler (intervalos em minutos) ---
SCHEDULE_AMAZON_MINUTES=5
SCHEDULE_MERCADOLIVRE_MINUTES=5
SCHEDULE_SHOPEE_MINUTES=5
SCHEDULE_PELANDO_MINUTES=2
SCHEDULE_PROMOBIT_MINUTES=2
