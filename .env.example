# --- Aplicação ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# URL pública onde este servidor é acessível (usada nos links de rastreio de clique enviados no WhatsApp)
PUBLIC_BASE_URL=http://localhost:3000

# --- Dashboard (HTTP Basic Auth opcional; deixe em branco para desativar em dev) ---
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# --- Banco de dados ---
DATABASE_URL="file:./src/database/dev.db"

# --- WhatsApp ---
WHATSAPP_GROUP_ID=
# Pasta onde a sessão do Baileys (QR/credenciais) é persistida. Nunca commitar.
WHATSAPP_AUTH_DIR=./auth
# Intervalo mínimo entre envios (ms), para evitar flood/banimento
WHATSAPP_MIN_INTERVAL_MS=20000

# --- IA (geração de texto da oferta) ---
# Em branco = usa o template fixo (sem IA). A IA nunca decide preço/desconto,
# só a frase de chamada — os valores são sempre os reais, adicionados pelo código.
OPENAI_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Links de afiliado ---
AFFILIATE_AMAZON=
AFFILIATE_SHOPEE=
AFFILIATE_MERCADOLIVRE=

# --- Filtros de validação de oferta ---
MIN_DISCOUNT_PERCENT=20
MIN_RATING=4
MIN_REVIEWS_COUNT=50
# Tolerância (p.p.) entre o desconto anunciado e o calculado a partir dos preços
FALSE_DISCOUNT_TOLERANCE_PERCENT=3
# Quanto o preço "de" pode exceder a média histórica antes de ser considerado inflado (%)
INFLATED_PRICE_TOLERANCE_PERCENT=30
# Frete acima desse % do preço da oferta é considerado abusivo
MAX_SHIPPING_PERCENT=20

# --- Scheduler (intervalos em minutos) ---
SCHEDULE_AMAZON_MINUTES=5
SCHEDULE_MERCADOLIVRE_MINUTES=5
SCHEDULE_SHOPEE_MINUTES=5
SCHEDULE_PELANDO_MINUTES=2
SCHEDULE_PROMOBIT_MINUTES=2
