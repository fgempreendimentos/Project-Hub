// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// --- Enums ---

enum SourceType {
  SCRAPING
  API
}

enum SourceStatus {
  ONLINE
  OFFLINE
}

enum OfferStatus {
  PENDING
  APPROVED
  REJECTED
  SENT
}

enum Channel {
  WHATSAPP
  TELEGRAM
  DISCORD
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

enum UserRole {
  ADMIN
}

// --- Models ---

// Uma fonte de ofertas (Mercado Livre, Amazon, Shopee, Pelando, Promobit...).
// `status`/`consecutiveFailures` alimentam o card "Fontes online/offline" do dashboard.
model Source {
  id                  String       @id @default(cuid())
  name                String       @unique
  slug                String       @unique
  type                SourceType   @default(SCRAPING)
  status              SourceStatus @default(ONLINE)
  scheduleMinutes     Int
  consecutiveFailures Int          @default(0)
  lastCheckedAt       DateTime?
  lastSuccessAt       DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  products Product[]

  @@map("sources")
}

// O produto em si, identificado pela fonte + id externo. Um produto acumula
// várias Offers (uma por ciclo de scraping em que o preço mudou) e várias
// History (todo preço observado, usado para calcular a média histórica).
model Product {
  id           String   @id @default(cuid())
  sourceId     String
  externalId   String
  title        String
  url          String
  imageUrl     String?
  category     String?
  rating       Float?
  reviewsCount Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  source  Source    @relation(fields: [sourceId], references: [id])
  offers  Offer[]
  history History[]

  @@unique([sourceId, externalId])
  @@map("products")
}

// Uma oferta detectada em um ciclo do pipeline. `dedupeHash` é a chave que
// impede reenviar a mesma oferta (mesmo produto + mesmo preço) mais de uma vez.
// `status`/`rejectionReason` registram o motivo de rejeição de cada validador
// (falso desconto, produto indisponível, frete abusivo, etc.) para auditoria.
model Offer {
  id              String      @id @default(cuid())
  productId       String
  originalPrice   Float
  offerPrice      Float
  discountPercent Float
  shippingCost    Float?
  available       Boolean     @default(true)
  affiliateUrl    String
  dedupeHash      String      @unique
  status          OfferStatus @default(PENDING)
  rejectionReason String?
  detectedAt      DateTime    @default(now())
  createdAt       DateTime    @default(now())

  product  Product   @relation(fields: [productId], references: [id])
  messages Message[]
  clicks   Click[]

  @@index([productId])
  @@index([status])
  @@map("offers")
}

// Série histórica de preços observados de um produto, independente do ciclo de
// vida da Offer (que também controla envio de mensagem). Existe separada de
// Offer porque alimenta o validador "preço abaixo da média histórica" mesmo
// para preços vistos em ofertas que acabaram rejeitadas por outro motivo.
model History {
  id           String   @id @default(cuid())
  productId    String
  price        Float
  shippingCost Float?
  observedAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId, observedAt])
  @@map("history")
}

// Uma mensagem enviada (ou a enviar) para um canal, referente a uma Offer
// aprovada. Suporta múltiplos canais (WhatsApp hoje, Telegram/Discord no
// futuro) e controla a fila de envio (status/attempts/error) para rate limit.
model Message {
  id        String        @id @default(cuid())
  offerId   String
  channel   Channel       @default(WHATSAPP)
  content   String
  imageUrl  String?
  status    MessageStatus @default(PENDING)
  attempts  Int           @default(0)
  error     String?
  sentAt    DateTime?
  createdAt DateTime      @default(now())

  offer Offer @relation(fields: [offerId], references: [id])

  @@index([status])
  @@map("messages")
}

// Registro de clique no link de afiliado de uma oferta (via endpoint de
// redirecionamento da API), usado para a métrica "clique por afiliado".
model Click {
  id        String   @id @default(cuid())
  offerId   String
  channel   Channel  @default(WHATSAPP)
  ipHash    String?
  userAgent String?
  clickedAt DateTime @default(now())

  offer Offer @relation(fields: [offerId], references: [id])

  @@index([offerId])
  @@map("clicks")
}

// Usuário administrador do dashboard (autenticação é implementada na Etapa 7).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

// Configurações em runtime que podem sobrepor o .env (ex.: ajustar
// MIN_DISCOUNT_PERCENT pelo dashboard sem redeploy).
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// Log persistido no banco (além dos arquivos do Winston) para o dashboard
// exibir "Erros" recentes sem precisar ler arquivos de log.
model Log {
  id        String   @id @default(cuid())
  level     LogLevel
  message   String
  context   String?
  createdAt DateTime @default(now())

  @@index([level, createdAt])
  @@map("logs")
}
